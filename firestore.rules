rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - The user's ID
    //   - data: string (required) - JSON stringified state
    //   - updatedAt: number (required) - Timestamp of the backup
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidBackup(data) {
      return data.keys().hasOnly(['uid', 'data', 'updatedAt']) &&
             data.uid is string &&
             data.data is string &&
             data.data.size() < 1000000 && // Max 1MB
             data.updatedAt is number;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
                    isValidBackup(request.resource.data) && 
                    request.resource.data.uid == userId;
      allow update: if isOwner(userId) && 
                    isValidBackup(request.resource.data) && 
                    request.resource.data.uid == userId;
      allow delete: if isOwner(userId);
    }
  }
}
